# SparkLab Docker Compose deployment
WEB_PORT=3000
BACKEND_PORT=3001

# Public URLs used by the browser and backend CORS.
# Change localhost to your server IP/domain after deploying to a host.
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal URL used by the Next.js container to reach the Go backend.
SERVER_URL=http://backend:3001

# Persistent SQLite database path inside the backend container.
DATABASE_URL=file:/app/data/spark_lab.db

# Change this before production use.
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN=7d

# Docker and update settings.
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_API_HTTP_TIMEOUT_SEC=300
GITHUB_REPO=opshenyi/SparkLab
GITHUB_BRANCH=main
GITHUB_TOKEN=
APP_REPO_DIR=/app/repo
UPDATE_CHECK_CACHE_SECONDS=300
UPDATE_SCRIPT_TIMEOUT_SECONDS=1200

# First boot will create demo data and an admin account if the database is empty.
# Default admin: admin / admin123
SEED_ON_START=true

# Optional Spark AI settings.
SPARK_AI_API_KEY=
SPARK_AI_API_URL=

GIN_MODE=release
TZ=Asia/Shanghai
