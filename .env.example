# SparkLab Docker Compose deployment
WEB_PORT=3000
BACKEND_PORT=3001

# Public URLs used by the browser and backend CORS.
# Change localhost to your server IP/domain after deploying to a host.
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal URL used by the Next.js container to reach the Go backend.
SERVER_URL=http://backend:3001

# Persistent SQLite database path inside the backend container.
DATABASE_URL=file:/app/data/spark_lab.db

# Production should use a stable random value, for example: openssl rand -hex 32
# If left empty, SparkLab generates an ephemeral runtime secret and old sessions expire after restart.
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_SECURE=
COOKIE_SAMESITE=lax

# Docker and update settings.
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_API_HTTP_TIMEOUT_SEC=300
GITHUB_REPO=opshenyi/SparkLab
GITHUB_BRANCH=main
GITHUB_TOKEN=
# Optional override for Docker-outside-of-Docker updates. Leave empty for auto-detection.
HOST_PROJECT_DIR=
APP_REPO_DIR=/app/repo
SPARKLAB_UPDATE_DIR=/app/data
UPDATE_CHECK_CACHE_SECONDS=300
UPDATE_SCRIPT_TIMEOUT_SECONDS=1200
# Set true only when you want Docker to refresh base images during updates.
SPARKLAB_BUILD_PULL=false

# First boot creates a bootstrap admin if the database is empty.
# Leave SPARKLAB_BOOTSTRAP_ADMIN_PASSWORD empty to generate a random password in data/server/bootstrap-admin.txt.
SEED_ON_START=true
SEED_DEMO_DATA=false
SPARKLAB_BOOTSTRAP_ADMIN_USERNAME=admin
SPARKLAB_BOOTSTRAP_ADMIN_PASSWORD=
SPARKLAB_BOOTSTRAP_ADMIN_DISPLAY_NAME=管理员
SPARKLAB_BOOTSTRAP_CREDENTIALS_FILE=/app/data/bootstrap-admin.txt
SPARKLAB_DEMO_STUDENT_PASSWORD=
SPARKLAB_ALLOW_INSECURE_DEFAULTS=false

# Optional Spark AI settings.
SPARK_AI_API_KEY=
SPARK_AI_API_URL=

GIN_MODE=release
TZ=Asia/Shanghai
