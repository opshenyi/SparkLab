# Database
DATABASE_URL="file:./prisma/spark_lab.db"

# Server Configuration
PORT=3001
HOST=localhost

# Docker Engine (local daemon)
DOCKER_HOST=unix:///var/run/docker.sock

# GitHub Updates
GITHUB_REPO=opshenyi/SparkLab
GITHUB_BRANCH=main
# Optional: increases GitHub API rate limit for update checks
# GITHUB_TOKEN=
# Optional: set when the server is not started from inside the repository
# APP_REPO_DIR=

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# CORS
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
