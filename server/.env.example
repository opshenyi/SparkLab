# SparkLab Docker deployment is configured from the repository root .env file.
# This file is kept only as a backend-only reference.

# Database
DATABASE_URL="file:/app/data/spark_lab.db"

# Server Configuration
PORT=3001

# Docker Engine (local daemon)
DOCKER_HOST=unix:///var/run/docker.sock

# GitHub Updates
GITHUB_REPO=opshenyi/SparkLab
GITHUB_BRANCH=main
UPDATE_CHECK_CACHE_SECONDS=300
UPDATE_SCRIPT_TIMEOUT_SECONDS=1200
# Optional: increases GitHub API rate limit for update checks
# GITHUB_TOKEN=
# Docker Compose deployments mount the host repository here.
APP_REPO_DIR=/app/repo

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# CORS
WEB_URL=http://localhost:3000

# Environment
GIN_MODE=release
