# API Configuration（终端 WebSocket 使用当前页面 hostname + 此处 URL 的端口，勿与页面域名混用 127.0.0.1 / localhost）
NEXT_PUBLIC_API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# 星火AI配置（可选）
# 如果不配置，将使用模拟响应进行开发测试
# 获取API密钥：https://console.xfyun.cn/
# SPARK_AI_API_KEY=your_spark_ai_api_key_here
# SPARK_AI_API_URL=https://spark-api.xf-yun.com/v1/chat/completions
